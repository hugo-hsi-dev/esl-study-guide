ORIGIN="http://localhost:5173"

# Better Auth
# For production, replace this with 32+ characters generated with high entropy.
# https://www.better-auth.com/docs/installation
BETTER_AUTH_SECRET="0123456789abcdef0123456789abcdef"

# Fixed test accounts. Run `pnpm auth:seed` after local migrations.
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="admin-password"
ADMIN_NAME="Test Admin"
LEARNER_USERNAME="learner"
LEARNER_PASSWORD="learner-password"
LEARNER_NAME="Test Learner"

# Workers AI MVP provider. Deployed app uses the AI binding.
WORKERS_AI_TEXT_MODEL_ID="@cf/zai-org/glm-4.7-flash"
WORKERS_AI_TRANSCRIPTION_MODEL_ID="@cf/openai/whisper-large-v3-turbo"
WORKERS_AI_TTS_MODEL_ID="@cf/myshell-ai/melotts"

# Remote Cloudflare D1 schema/seed maintenance.
CLOUDFLARE_ACCOUNT_ID=""
CLOUDFLARE_D1_DATABASE_ID=""
CLOUDFLARE_API_TOKEN=""
