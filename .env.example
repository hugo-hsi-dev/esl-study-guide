ORIGIN="http://localhost:5173"

# Better Auth
# For production, replace this with 32+ characters generated with high entropy.
# https://www.better-auth.com/docs/installation
BETTER_AUTH_SECRET="0123456789abcdef0123456789abcdef"

# GitHub OAuth
# Replace these with a real OAuth app to test GitHub login locally.
# https://www.better-auth.com/docs/authentication/github
GITHUB_CLIENT_ID="dev-client-id"
GITHUB_CLIENT_SECRET="dev-client-secret"

# Comma-separated emails that should become Admin accounts at sign-up
ADMIN_EMAILS="admin@example.com"

# Optional: Drizzle D1 HTTP driver for remote D1 maintenance
CLOUDFLARE_ACCOUNT_ID=""
CLOUDFLARE_D1_DATABASE_ID=""
CLOUDFLARE_API_TOKEN=""
