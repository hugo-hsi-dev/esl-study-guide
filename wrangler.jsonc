{
	"$schema": "./node_modules/wrangler/config-schema.json",
	"name": "esl-study-guide",
	"compatibility_date": "2026-07-08",
	"compatibility_flags": ["nodejs_als"],
	"main": ".svelte-kit/cloudflare/_worker.js",
	"assets": {
		"binding": "ASSETS",
		"directory": ".svelte-kit/cloudflare"
	},
	"ai": {
		"binding": "AI"
	},
	"vars": {
		"ORIGIN": "https://esl-study-guide.hugo-hsi.workers.dev",
		"ADMIN_EMAILS": "",
		"WORKERS_AI_TEXT_MODEL_ID": "@cf/zai-org/glm-4.7-flash",
		"WORKERS_AI_TRANSCRIPTION_MODEL_ID": "@cf/openai/whisper-large-v3-turbo",
		"WORKERS_AI_TTS_MODEL_ID": "@cf/myshell-ai/melotts"
	},
	"d1_databases": [
		{
			"binding": "DB",
			"database_name": "esl-study-guide",
			"database_id": "6cc1f525-5e7b-45c6-a7bf-edfe6aa13af5",
			"migrations_dir": "drizzle"
		}
	],
	"workers_dev": true,
	"preview_urls": true
}
